            "value": 1
          },
          "maxReplicas": {
            "value": 1
          },
          "plainEnv": {
            "value": [
              {
                "name": "NODE_ENV",
                "value": "production"
              },
              {
                "name": "PORT",
                "value": "3000"
              },
