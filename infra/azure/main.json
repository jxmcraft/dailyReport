            }
          },
          "parameters": {
            "location": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "environmentId": {
              "type": "string"
            },
            "containerImage": {
              "type": "string"
            },
            "acrLoginServer": {
              "type": "string"
            },
            "keyVaultUri": {
              "type": "string"
            },
            "ingressEnabled": {
              "type": "bool"
            },
            "targetPort": {
              "type": "int"
            },
            "readinessPath": {
              "type": "string",
              "defaultValue": "/api/health",
              "metadata": {
                "description": "HTTP path for readiness probe (DB check)"
              }
            },
            "livenessPath": {
              "type": "string",
              "defaultValue": "/api/health/live",
              "metadata": {
                "description": "HTTP path for liveness probe (process up, no DB)"
              }
            },
            "healthPort": {
              "type": "int"
            },
            "minReplicas": {
              "type": "int"
            },
            "maxReplicas": {
              "type": "int"
            },
            "plainEnv": {
              "type": "array"
            },
            "keyVaultSecretNames": {
              "type": "array"
            },
            "containerCommand": {
              "type": "array",
              "defaultValue": []
            }
          },
          "variables": {
            "copy": [
              {
                "name": "kvSecrets",
                "count": "[length(parameters('keyVaultSecretNames'))]",
                "input": {
                  "name": "[toLower(parameters('keyVaultSecretNames')[copyIndex('kvSecrets')])]",
                  "identity": "system",
                  "keyVaultUrl": "[format('{0}secrets/{1}', parameters('keyVaultUri'), parameters('keyVaultSecretNames')[copyIndex('kvSecrets')])]"
                }
              },
              {
                "name": "secretEnv",
                "count": "[length(parameters('keyVaultSecretNames'))]",
                "input": {
                  "name": "[if(equals(parameters('keyVaultSecretNames')[copyIndex('secretEnv')], 'DATABASE-URL'), 'DATABASE_URL', replace(parameters('keyVaultSecretNames')[copyIndex('secretEnv')], '-', '_'))]",
                  "secretRef": "[toLower(parameters('keyVaultSecretNames')[copyIndex('secretEnv')])]"
                }
              }
            ]
          },
          "resources": [
            {
              "type": "Microsoft.App/containerApps",
              "apiVersion": "2024-03-01",
              "name": "[parameters('name')]",
              "location": "[parameters('location')]",
              "identity": {
                "type": "SystemAssigned"
              },
              "properties": {
                "environmentId": "[parameters('environmentId')]",
                "configuration": {
                  "ingress": "[if(parameters('ingressEnabled'), createObject('external', true(), 'targetPort', parameters('targetPort'), 'transport', 'auto', 'allowInsecure', false()), null())]",
                  "secrets": "[variables('kvSecrets')]",
                  "registries": [
                    {
                      "server": "[parameters('acrLoginServer')]",
                      "identity": "system"
                    }
                  ]
                },
                "template": {
                  "containers": [
                    {
                      "name": "app",
                      "image": "[parameters('containerImage')]",
                      "command": "[if(greater(length(parameters('containerCommand')), 0), parameters('containerCommand'), null())]",
                      "env": "[concat(parameters('plainEnv'), variables('secretEnv'))]",
                      "probes": [
                        {
                          "type": "Liveness",
                          "httpGet": {
                            "path": "[parameters('livenessPath')]",
                            "port": "[parameters('healthPort')]"
