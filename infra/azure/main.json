      "type": "securestring",
      "metadata": {
        "description": "PostgreSQL administrator password"
      }
    },
    "postgresAdminLogin": {
      "type": "string",
      "defaultValue": "newsadmin"
    },
    "postgresSku": {
      "type": "string",
      "defaultValue": "B_Standard_B1ms"
    },
    "postgresDbName": {
      "type": "string",
      "defaultValue": "newsagent"
    },
    "assignManagedIdentityRoles": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "Create AcrPull + Key Vault Secrets User role assignments for Container App identities. Requires Owner or User Access Administrator on the RG/subscription. Set false if an admin will assign roles manually."
      }
    }
  },
  "variables": {
    "namePrefix": "[parameters('environmentName')]",
    "postgresServerName": "[format('{0}-pg-{1}', variables('namePrefix'), uniqueString(resourceGroup().id))]",
