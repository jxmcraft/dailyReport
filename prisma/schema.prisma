datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum AgentStatus {
  ACTIVE
  PAUSED
  RUNNING
}

enum SourceType {
  NEWS_API
  GOOGLE_SEARCH
  CUSTOM_SCRAPE
  FINANCIAL_STREAM
}

enum DeliveryTarget {
  SLACK
  EMAIL
  DISCORD
}

enum ExecutionStatus {
  SUCCESS
  PARTIAL_FAILURE
  CRITICAL_ERROR
}

enum EmailDeliveryStatus {
  NOT_APPLICABLE
  PENDING_REVIEW
  DISTRIBUTED
  EXPIRED
}

model WorkspaceSettings {
  id                   Int      @id @default(1)
  llmTimeoutMs         Int      @default(180000)
  sourceFetchTimeoutMs Int      @default(60000)
  activeRunPollMs      Int      @default(4000)
  updatedAt            DateTime @updatedAt
}

model Agent {
  id               String               @id @default(uuid())
  name             String
  topicKeywords    String[]
  cronSchedule     String
  systemPrompt       String               @db.Text
  relevanceMinScore  Int                  @default(3)
  minRankedSources   Int                  @default(3)
  keywordMatchMode   String               @default("OR")
  status             AgentStatus          @default(ACTIVE)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  dataSources      DataSource[]
  deliveryChannels DeliveryChannel[]
  reports          IntelligenceReport[]
}

model DataSource {
  id               String     @id @default(uuid())
  agentId          String
  agent            Agent      @relation(fields: [agentId], references: [id], onDelete: Cascade)
  sourceType       SourceType
  apiEndpoint      String
  authSecretKeyRef String
}

model DeliveryChannel {
  id                   String         @id @default(uuid())
  agentId              String
  agent                Agent          @relation(fields: [agentId], references: [id], onDelete: Cascade)
  target               DeliveryTarget
  webhookUrl           String
  recipientList        String[]
  approverList         String[]       @default([])
  requireEmailApproval Boolean        @default(true)
  autoSendEmail        Boolean        @default(true)
}

model IntelligenceReport {
  id                     String               @id @default(uuid())
  agentId                String
  agent                  Agent                @relation(fields: [agentId], references: [id], onDelete: Cascade)
  timestamp              DateTime             @default(now())
  rawIngestedDataCount   Int
  generatedMarkdown      String               @db.Text
  status                 ExecutionStatus
  statusNotes            String[]             @default([])
  sourcesUsed            Json
  sourceDiagnostics      Json?
  emailDeliveryStatus    EmailDeliveryStatus  @default(NOT_APPLICABLE)
  emailApprovalTokenHash String?
  emailApprovedAt        DateTime?
  emailApprovedBy        String?
}
