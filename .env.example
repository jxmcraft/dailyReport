# --- Required ---
# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://user:password@localhost:5432/pulseagent?schema=public"

# --- LLM (set one provider path) ---
# LLM provider: openrouter (default) or deepseek
LLM_PROVIDER="openrouter"

# OpenRouter (OpenAI-compatible) — set OPENROUTER_MODEL to a fast paid model for production
OPENROUTER_API_KEY="sk-or-v1-..."
OPENROUTER_MODEL="poolside/laguna-m.1:free"
OPENROUTER_OPTIMIZER_MODEL=""

# DeepSeek (optional) — set LLM_PROVIDER=deepseek when ready
DEEPSEEK_API_KEY=""
DEEPSEEK_MODEL="deepseek-chat"
DEEPSEEK_BASE_URL="https://api.deepseek.com"

# --- Production web (required when using email approval or public links) ---
# Public base URL for email approval links (no trailing slash).
# Dev: set to the port you use (e.g. http://localhost:3001). If unset, falls back to http://localhost:${PORT} (default 3000).
APP_URL="http://localhost:3000"

# --- Scheduler (recommended in production) ---
# IANA timezone for the scheduler process — cron is evaluated in this timezone
# Example: America/New_York, Europe/London, UTC
TZ="UTC"

# --- External data source keys (optional — built-in providers run when keys are set) ---
NEWS_API_KEY=""          # https://newsapi.org/
GNEWS_API_KEY=""         # https://gnews.io/
CURRENTS_API_KEY=""      # https://currentsapi.services/
MARKETAUX_API_KEY=""     # https://www.marketaux.com/
GUARDIAN_API_KEY=""      # https://open-platform.theguardian.com/
MEDIASTACK_API_KEY=""    # https://mediastack.com/
GOOGLE_SEARCH_API_KEY=""
GOOGLE_SEARCH_CX=""

# Reddit username used to build the public .json User-Agent (no OAuth required).
REDDIT_USER="YourRedditUser"

# --- Email delivery (optional — when agents use Email target) ---
# Gmail: smtp.gmail.com, port 587, your address, and a Google App Password (not your login password).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Secret pepper for hashing approval tokens — required when email approval is enabled
EMAIL_APPROVAL_SECRET=""

# --- Microsoft Graph (optional — EMAIL_PROVIDER=graph) ---
# Application permissions: Group.Read.All, User.Read.All, Mail.Send (admin consent).
# See docs/azure/MICROSOFT_GRAPH.md
EMAIL_PROVIDER="smtp"
AZURE_TENANT_ID=""
AZURE_CLIENT_ID=""
AZURE_CLIENT_SECRET=""
GRAPH_SENDER_UPN=""

# --- Azure production (see docs/azure/DEPLOY.md) ---
# APP_URL=https://your-app.azurecontainerapps.io
# TZ=America/New_York

# Bearer token for POST /api/pipeline/[agentId]/run automation (optional in dev)
API_SECRET=""

# Note: LLM timeout, source fetch timeout, and active-run poll interval are workspace
# settings on the Settings page (database), not environment variables.
